{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/dashboard",
      "permanent": false
    },
    {
      "source": "/verb-your-body-part-direction",
      "destination": "/your-cues",
      "permanent": true
    },
    {
      "source": "/teaching-log",
      "destination": "/teaching-notes",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/@:handle",
      "destination": "/teacher"
    }
  ]
}